# Discord
DISCORD_TOKEN=your-bot-token
GUILD_ID=000000000000000000
CHECKIN_CHANNEL_ID=000000000000000000
# Optional: role allowed to run captain commands (0 = Administrator permission only)
CAPTAIN_ROLE_ID=000000000000000000

# Scheduling (local times, in TIMEZONE below)
TIMEZONE=America/Chicago
TIMEZONE_LABEL=CT
CHECKIN_TIME=12:00
EVENT_TIME=19:00
# Responses lock this many minutes before kickoff (60 = one hour before)
LOCK_OFFSET_MINUTES=60

# Database
DATABASE_URL=sqlite+aiosqlite:///./proclubs.db
